<!DOCTYPE html>
<html lang="{{ lang_cfg.html_lang }}">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{ post.title }} | TonForce</title>
<meta name="description" content="{{ post.meta_description }}" />
<meta name="robots" content="index, follow, max-image-preview:large" />

<link rel="canonical" href="{{ post_url }}" />
<link rel="alternate" hreflang="ru" href="{{ alt_links.ru }}" />
<link rel="alternate" hreflang="en" href="{{ alt_links.en }}" />
<link rel="alternate" hreflang="uk" href="{{ alt_links.ua }}" />
<link rel="alternate" hreflang="x-default" href="{{ alt_links.ru }}" />

<meta property="og:type" content="article" />
<meta property="og:url" content="{{ post_url }}" />
<meta property="og:title" content="{{ post.title }}" />
<meta property="og:description" content="{{ post.lead }}" />
<meta property="og:image" content="{{ site_url }}/og-image.jpg" />
<meta property="og:locale" content="{{ lang_cfg.og_locale }}" />
<meta property="article:published_time" content="{{ iso_published }}" />
<meta property="article:section" content="{{ category_label }}" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="{{ post.title }}" />
<meta name="twitter:description" content="{{ post.lead }}" />
<meta name="twitter:image" content="{{ site_url }}/og-image.jpg" />

<link rel="icon" href="/favicon.png" type="image/png" />
<link rel="apple-touch-icon" href="/favicon.png" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Bruno+Ace+SC&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

<link rel="stylesheet" href="/blog/blog.css" />

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ post.title | tojson }},
  "description": {{ post.lead | tojson }},
  "image": "{{ site_url }}/og-image.jpg",
  "datePublished": "{{ iso_published }}",
  "dateModified": "{{ iso_published }}",
  "author": {
    "@type": "Organization",
    "name": "TonForce",
    "url": "{{ site_url }}/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "TonForce",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ site_url }}/logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ post_url }}"
  },
  "inLanguage": "{{ lang_cfg.html_lang }}"
}
</script>
</head>
<body>

<nav class="nav" role="navigation">
  <div class="nav-inner">
    <a href="/{% if lang != 'ru' %}{{ lang }}/{% endif %}" class="nav-logo" aria-label="TonForce">
      <img src="/logo-white.png" alt="TonForce" width="36" height="36" />
      <span>TONFORCE</span>
    </a>
    <ul class="nav-links">
      <li><a href="/{% if lang != 'ru' %}{{ lang }}/{% endif %}#about">{{ labels.nav_about }}</a></li>
      <li><a href="/{% if lang != 'ru' %}{{ lang }}/{% endif %}#security">{{ labels.nav_security }}</a></li>
      <li><a href="/{% if lang != 'ru' %}{{ lang }}/{% endif %}#levels">{{ labels.nav_levels }}</a></li>
      <li><a href="{{ blog_base }}">{{ labels.nav_blog }}</a></li>
    </ul>
    <div class="nav-right">
      <div class="lang-switcher">
        <a href="/blog/" {% if lang == 'ru' %}class="active" aria-current="page"{% endif %} hreflang="ru">RU</a>
        <a href="/en/blog/" {% if lang == 'en' %}class="active" aria-current="page"{% endif %} hreflang="en">EN</a>
        <a href="/ua/blog/" {% if lang == 'ua' %}class="active" aria-current="page"{% endif %} hreflang="uk">UA</a>
      </div>
      <a href="https://t.me/tonforce_bot/tonforce" class="btn" target="_blank" rel="noopener">
        {{ labels.launch_btn }}
      </a>
    </div>
  </div>
</nav>

<main>
  <article class="post-page">
    <div class="container">
      <a href="{{ blog_base }}" class="post-back">{{ labels.back_to_blog }}</a>

      <div class="post-header">
        <div class="post-meta">
          <span class="post-tag">{{ category_label }}</span>
          <span>📅 {{ formatted_date }}</span>
          <span>⏱ {{ post.read_time }} {{ labels.min_label }}</span>
        </div>
        <h1 class="post-title">{{ post.title }}</h1>
        <p class="post-lead">{{ post.lead }}</p>
      </div>

      {% if post.cover_image %}
      <div class="post-cover">
        <img src="{{ post.cover_image }}" alt="{{ post.title }}" loading="lazy" />
      </div>
      {% else %}
      <div class="post-cover placeholder">{{ post.cover_emoji }}</div>
      {% endif %}

      <div class="post-content">
        {{ post.body_html | safe }}
      </div>

      <div class="post-share">
        <div class="post-share-label">{{ labels.share_label }}</div>
        <div class="post-share-buttons">
          <a href="https://t.me/share/url?url={{ post_url | urlencode }}&text={{ share_text_encoded }}" target="_blank" rel="noopener" class="share-btn share-tg">Telegram</a>
          <a href="https://twitter.com/intent/tweet?url={{ post_url | urlencode }}&text={{ share_text_encoded }}" target="_blank" rel="noopener" class="share-btn share-tw">Twitter / X</a>
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ post_url | urlencode }}" target="_blank" rel="noopener" class="share-btn share-fb">Facebook</a>
          <a href="https://vk.com/share.php?url={{ post_url | urlencode }}&title={{ share_text_encoded }}" target="_blank" rel="noopener" class="share-btn share-vk">VK</a>
          <a href="https://api.whatsapp.com/send?text={{ share_text_encoded }}%20{{ post_url | urlencode }}" target="_blank" rel="noopener" class="share-btn share-wa">WhatsApp</a>
          <button onclick="copyLink(this)" class="share-btn share-copy" data-url="{{ post_url }}" data-copied="{{ labels.share_copied }}" data-original="{{ labels.share_copy }}">{{ labels.share_copy }}</button>
        </div>
      </div>

      <div class="post-comments">
        <div class="post-comments-title">{{ labels.comments_title }}</div>
        <div id="disqus_thread"></div>
        <script>
          var disqus_config = function () {
            this.page.url = '{{ post_url }}';
            this.page.identifier = '{{ post.slug }}-{{ lang }}';
          };
          (function() {
            var d = document, s = d.createElement('script');
            s.src = 'https://tonforce.disqus.com/embed.js';
            s.setAttribute('data-timestamp', +new Date());
            (d.head || d.body).appendChild(s);
          })();
        </script>
        <noscript>Please enable JavaScript to view comments powered by Disqus.</noscript>
      </div>
    </div>
  </article>

  {% if related %}
  <section class="related-posts">
    <div class="container">
      <h2><span class="gradient">{{ labels.related_posts }}</span></h2>
      <div class="posts-grid">
        {% for rp in related %}
        <a href="{{ rp.slug }}.html" class="post-card">
          {% if rp.cover_image %}
          <div class="post-card-image"><img src="{{ rp.cover_image }}" alt="{{ rp.title }}" loading="lazy" /></div>
          {% else %}
          <div class="post-card-image placeholder">{{ rp.cover_emoji }}</div>
          {% endif %}
          <div class="post-card-body">
            <div class="post-card-meta">
              <span class="post-card-tag">{{ labels.categories.get(rp.category, rp.category) }}</span>
              <span>{{ rp.date.strftime('%Y-%m-%d') }}</span>
            </div>
            <h3 class="post-card-title">{{ rp.title }}</h3>
            <div class="post-card-readmore">{{ labels.read_more }}</div>
          </div>
        </a>
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}
</main>

<footer role="contentinfo">
  <div class="container">
    <div class="footer-links">
      <a href="/{% if lang != 'ru' %}{{ lang }}/{% endif %}">{{ labels.footer_brand }}</a>
      <a href="{{ blog_base }}">{{ labels.footer_blog }}</a>
      <a href="/{% if lang != 'ru' %}{{ lang }}/{% endif %}#about">{{ labels.footer_about }}</a>
      <a href="/{% if lang != 'ru' %}{{ lang }}/{% endif %}#security">{{ labels.footer_security }}</a>
      <a href="https://t.me/tonforce_bot" target="_blank" rel="noopener">Telegram Bot</a>
      <a href="https://t.me/chat_tonforce" target="_blank" rel="noopener">Telegram Chat</a>
      <a href="https://github.com/spsonlys/tonforce" target="_blank" rel="noopener">GitHub</a>
    </div>
    <div>{{ labels.footer_copy }}</div>
  </div>
</footer>

<script>
function copyLink(btn) {
  var url = btn.getAttribute('data-url');
  var copiedText = btn.getAttribute('data-copied');
  var originalText = btn.getAttribute('data-original');
  navigator.clipboard.writeText(url).then(function() {
    btn.classList.add('copied');
    btn.textContent = copiedText;
    setTimeout(function() {
      btn.classList.remove('copied');
      btn.textContent = originalText;
    }, 2000);
  });
}
</script>

</body>
</html>
